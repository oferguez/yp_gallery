---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout title={`Contact | ${siteConfig.artistName}`}>
  <section class="container-shell page-intro">
    <p class="eyebrow">Contact</p>
    <h1>Studio and inquiries</h1>
    <p class="max-copy">This starter keeps contact static. Add your preferred form provider later if needed.</p>
  </section>

  <section class="container-shell section-spacing contact-card" aria-label="Contact details">
    <h2>{siteConfig.artistName}</h2>
    <p><a class="text-link" href="mailto:studio@example.com">studio@example.com</a></p>
    <p>Instagram: <a class="text-link" href="https://instagram.com" target="_blank" rel="noreferrer">@artiststudio</a></p>
    <p class="muted">Representation placeholder: Meridian Works, London</p>
  </section>
</BaseLayout>
