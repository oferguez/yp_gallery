---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { rooms, siteConfig } from '../../config/site';
import { unsplashSrc } from '../../lib/images';
import { withBase } from '../../lib/urls';

const paintings = (await getCollection('paintings')).sort((a, b) => a.data.order - b.data.order);

// Grid positions: x = column, y = row (top-left corner of each card)
// dx/dy = optional fine-tune nudge in card-size units (e.g. dx: 0.5 shifts right by half a card)
const gridPoints: Record<string, { x: number; y: number; dx?: number; dy?: number }> = {
  foyer:           { x: 0, y: 0 },
  'north-light':   { x: 2, y: 0 },
  'paper-archive': { x: 0, y: 1 },
  'mineral-room':  { x: 1.333, y: 1 },
  'river-gallery': { x: 2.666, y: 1 },
  'ember-wing':    { x: 2, y: 2 }
};

const roomCards = rooms.map((room) => {
  const firstPainting = paintings.find((painting) => painting.data.room === room.id);
  return {
    room,
    coverImage: firstPainting ? unsplashSrc(firstPainting.data.coverImage, 1200) : ''
  };
});

const edgeSet = new Set<string>();
for (const room of rooms) {
  for (const target of room.connectedTo) {
    const edgeId = [room.id, target].sort().join('::');
    edgeSet.add(edgeId);
  }
}

const edges = [...edgeSet].map((edge) => {
  const [fromId, toId] = edge.split('::');
  return { fromId, toId };
});
---

<BaseLayout title={`Browse Rooms | ${siteConfig.artistName}`}>
  <section class="container-shell page-intro">
    <p class="eyebrow">Browse</p>
    <h1>Room map</h1>
    <p class="max-copy">Choose a room to enter. Connected rooms are linked through the map network.</p>
  </section>

  <section class="container-shell section-spacing" aria-label="Room connectivity map">
    <div class="room-graph-scroll">
    <div class="room-graph">
      <svg class="room-lines" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
        {edges.map((edge) => (
          <line
            x1="0" y1="0" x2="0" y2="0"
            data-from={edge.fromId}
            data-to={edge.toId}
          ></line>
        ))}
      </svg>

      {roomCards.map(({ room, coverImage }) => (
        <a
          class="room-node"
          href={withBase(`/browse/${room.id}/`)}
          data-room-id={room.id}
          data-grid-x={gridPoints[room.id].x}
          data-grid-y={gridPoints[room.id].y}
          data-nudge-x={gridPoints[room.id].dx ?? 0}
          data-nudge-y={gridPoints[room.id].dy ?? 0}
        >
          {coverImage && <img class="room-node-bg" src={coverImage} alt="" aria-hidden="true" loading="lazy" />}
          <div class="room-node-copy">
            <h2>{room.name}</h2>
            <p>{room.description}</p>
          </div>
        </a>
      ))}
    </div>
    </div>
  </section>
</BaseLayout>

<script>
  type Point = { x: number; y: number; dx: number; dy: number };

  const graph = document.querySelector<HTMLElement>('.room-graph');
  const nodes = document.querySelectorAll<HTMLAnchorElement>('.room-node[data-room-id]');
  const lines = document.querySelectorAll<SVGLineElement>('.room-lines line');

  const points = new Map<string, Point>();
  nodes.forEach((node) => {
    const roomId = node.dataset.roomId;
    const x = Number(node.dataset.gridX);
    const y = Number(node.dataset.gridY);
    const dx = Number(node.dataset.nudgeX);
    const dy = Number(node.dataset.nudgeY);
    if (!roomId || Number.isNaN(x) || Number.isNaN(y)) return;
    points.set(roomId, { x, y, dx, dy });
  });

  const maxX = Math.max(...[...points.values()].map((p) => p.x));
  const maxY = Math.max(...[...points.values()].map((p) => p.y));

  const scroll = graph?.parentElement;

  const place = () => {
    if (!graph || !scroll) return;

    const isWide = scroll.offsetWidth > 800;
    const cardSize = scroll.offsetWidth / 5;
    const cardHeight = isWide ? graph.offsetHeight / 5 : cardSize;
    const rowSpan = cardHeight * 1.5;
    const inset = cardSize * 0.1;
    const canvasW = 2 * inset + (maxX + 1) * cardSize;
    const canvasH = 2 * inset + maxY * rowSpan + cardHeight;

    if (!isWide) graph.style.height = `${canvasH}px`;
    graph.style.minWidth = `${canvasW}px`;

    // pixel position of a card's top-left corner
    const px = (p: Point) => inset + p.x * cardSize + p.dx * cardSize;
    const py = (p: Point) => inset + p.y * rowSpan + p.dy * cardHeight;

    nodes.forEach((node) => {
      const point = points.get(node.dataset.roomId!);
      if (!point) return;
      node.style.left = `${px(point)}px`;
      node.style.top = `${py(point)}px`;
      node.style.width = `${cardSize}px`;
      node.style.height = `${cardHeight}px`;
    });

    const graphW = graph.offsetWidth;

    lines.forEach((line) => {
      const from = points.get(line.dataset.from!);
      const to = points.get(line.dataset.to!);
      if (!from || !to) return;
      // center of each card as % of graph dimensions
      const cx = (p: Point) => ((px(p) + cardSize / 2) / graphW) * 100;
      const cy = (p: Point) => ((py(p) + cardHeight / 2) / canvasH) * 100;
      line.setAttribute('x1', String(cx(from)));
      line.setAttribute('y1', String(cy(from)));
      line.setAttribute('x2', String(cx(to)));
      line.setAttribute('y2', String(cy(to)));
    });
  };

  window.addEventListener('resize', place);
  place();
</script>
