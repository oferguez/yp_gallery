---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PaintingCard from '../components/PaintingCard.astro';
import { siteConfig } from '../config/site';

const paintings = (await getCollection('paintings')).sort((a, b) => a.data.order - b.data.order);
const featured = paintings.filter((painting) => painting.data.featured).slice(0, 4);
---

<BaseLayout title={`${siteConfig.artistName} | Contemporary Paintings`}>
  <section class="hero container-shell">
    <p class="hero-kicker">{siteConfig.artistName}</p>
    <h1>Paintings that reward slow looking.</h1>
    <p class="hero-text">{siteConfig.homeIntro}</p>
  </section>

  <section class="container-shell section-spacing" aria-labelledby="journal-title">
    <div class="section-head">
      <h2 id="journal-title">Journal</h2>
    </div>
    <div class="journal-grid">
      <article class="journal-card">
        <p class="eyebrow">Field Notes · March 2026</p>
        <h3>Walking the Venice Biennale: Notes on Scale, Silence, and Surface</h3>
        <p>
          Last week in Venice, I spent long hours moving between national pavilions and quieter collateral
          spaces. What stayed with me most was how many strong works trusted restraint: fewer gestures,
          slower pacing, and surfaces that reveal themselves over time. I returned to the studio with a sharper
          sense of scale and with new attention to how a painting holds stillness in a crowded visual world.
        </p>
      </article>
      <article class="journal-card">
        <p class="eyebrow">Exhibition · Upcoming</p>
        <h3>Upcoming Exhibition: Tidal Interiors at Meridian Works, London</h3>
        <p>
          A new body of paintings will open this May at Meridian Works, centered on horizon fragments,
          diffused light, and layered mineral color. The exhibition brings together large canvases and a group
          of smaller perimeter studies developed over the past year. Full details and preview images will be
          shared soon.
        </p>
      </article>
    </div>
  </section>

  <section class="container-shell section-spacing" aria-labelledby="featured-title">
    <div class="section-head">
      <h2 id="featured-title">Featured works</h2>
      <a href="/paintings" class="text-link">Browse full catalogue</a>
    </div>
    <div class="paintings-grid">
      {featured.map((painting) => <PaintingCard painting={painting} />)}
    </div>
  </section>

  <section class="container-shell section-spacing intro-block" aria-labelledby="intro-title">
    <h2 id="intro-title">Studio notes</h2>
    <p>
      Current work explores shifts between built surfaces and open horizon, using oil, wax medium,
      and dry pigment in thin passes. Each canvas is developed over months, with pauses built into the process.
    </p>
  </section>
</BaseLayout>
