---
import { themeOptions } from '../config/site';
---

<label class="theme-switcher" for="theme-select">
  Theme
  <select id="theme-select" aria-label="Select site theme">
    {themeOptions.map((theme) => (
      <option value={theme.name}>{theme.label}</option>
    ))}
  </select>
</label>

<script>
  const root = document.documentElement;
  const themeSelect = document.querySelector<HTMLSelectElement>('#theme-select');
  const savedTheme = localStorage.getItem('gallery-theme');

  if (savedTheme) {
    root.dataset.theme = savedTheme;
  }

  if (themeSelect) {
    if (root.dataset.theme) {
      themeSelect.value = root.dataset.theme;
    }

    themeSelect.addEventListener('change', () => {
      const theme = themeSelect.value;
      root.dataset.theme = theme;
      localStorage.setItem('gallery-theme', theme);
    });
  }
</script>
